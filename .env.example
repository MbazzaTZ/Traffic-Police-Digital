# =========================================================
# TPDOP – Environment Variables Template
# Copy to .env.local and fill in your Supabase credentials
# ⚠️  Never commit .env.local with real values
# =========================================================

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

VITE_APP_NAME=TPDOP
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

VITE_ENABLE_GPS=true
VITE_ENABLE_BIOMETRIC=false
VITE_ENABLE_AUDIT=true
VITE_ENABLE_INTELLIGENCE=true
